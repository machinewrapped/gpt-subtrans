QWidget {
    font-family:system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
    font-size: 10pt;
}

QDialog, QTabWidget, QFrame {
    background-color: aliceblue;
}

QTabBar::tab {
    background: #e0e0e0;
    color: black;
    border: 1px solid #c0c0c0;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    padding: 4px;
    margin: 2px;
    margin-bottom: 0px;
}

QTabBar::tab:selected {
    background: lavenderblush;
    padding-bottom: 6px;
}

QLabel {
    color: black;
    padding-top: 2px;
    padding-bottom: 6px;
}

QComboBox {
    color: black;
    background: white;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    padding: 1px 18px 1px 3px;
    min-width: 6em;
    min-height: 1em;
}

QComboBox::drop-down QAbstractItemView, QComboBox QAbstractItemView::item {
    background-color: white;
    color: black;
}

QComboBox::down-button {
    border: 1px solid #c0c0c0;
}

QCheckBox::indicator {
    color: black;
    background: white;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
}

QCheckBox::indicator:checked {
    background: #404040;
    color: red;
}

QLineEdit, QTextEdit {
    color: black;
    background: white;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    selection-background-color: #d0d0d0;
}

QPushButton, QToolTip {
    color: black;
    background: white;
    padding: 2px 8px 3px 8px;
    border: 1px solid #c0c0c0;
    border-radius: 4px;
}

QSpinBox, QDoubleSpinBox {
    selection-background-color: #d0d0d0;
}

QSpinBox::text, QDoubleSpinBox::text {
    color: black;
    background-color: white;
}

/*
QSpinBox::up-button, QSpinBox::down-button, QDoubleSpinBox::up-button, QDoubleSpinBox::down-button {
    border: 1px solid #c0c0c0;
    color: black;
}

QSpinBox::up-arrow, QSpinBox::down-arrow, QDoubleSpinBox::up-arrow, QDoubleSpinBox::down-arrow {
    background: lavenderblush;
    color: black;
}
*/

QScrollBar, QSplitter::handle {
    background: lavenderblush;
}

QStatusBar {
    color: black;
}

.MainToolbar, .ProjectToolbar {
    background-color: #a0a0a0;
    border: none;
}

QTreeView:item {
    border-radius: 12;
}

QTreeView:item:selected {
    border: 2px solid black;
    border-radius: 12;
}

QListView:item {
    padding: 0px;
}

.MainWindow {
    background-color: aliceblue;
    color: black;
}

.LogWindow {
    background-color: #121212;
    border: 1px solid #242424;
}

.ScenesView {
    background-color: lightyellow;
}

.TreeViewItemWidget {
    padding: 1px;
    margin: 0px;
    border-width: 2;
    border-style: solid;
    border-color: lightgray;
    border-radius: 12;
    background-color: white;
}

.WidgetHeader {
    font-size: 12pt;
    font-weight: bold;
    padding: 10px 4px 4px 4px;
    color: black;
}

.WidgetHeader[all_translated=true] {
    background-color: blanchedalmond;
}

.WidgetHeader[all_translated=false] {
    background-color: burlywood;
}

.WidgetHeader[errors=true], .WidgetBody[errors=true] {
    color: red;
}

.WidgetSubheading {
    font-size: 10pt;
    margin: 0px;
    padding: 10px 3px 3px 3px;
    background-color: lavenderblush;
    color: black;
}

.WidgetFooter {
    margin: 0px;
    padding: 2px;
    padding-right: 10px;
}

.WidgetFooter QLabel {
    margin: 0px;
    padding: 0px;
}

.WidgetFooter[all_translated=true] QLabel {
    color: peru;
}

.WidgetFooter[all_translated=false] QLabel {
    color: saddlebrown;
}

.WidgetBody {
    font-size: 10pt;
    padding: 2px;
    padding-left: 10px;
    background-color: white;
    color: black;
}

.SubtitleView {
    padding: 1px;
}

.LineItemView {
    padding: 0px;
    margin: 1px;
    background-color: white;
}

.LineItemHeader {
    margin: 0px;
    padding: 2px;
    background-color: aliceblue;
    color: black;
}

.LineItemHeader QLabel {
    margin: 0px;
    padding-bottom: 6px;
}

#line-header-left {
    font-weight: bold;
}

#line-header-right {
    color: peru;
    font-size: 9pt;
}

.LineItemBody {
    margin: 2px;
    padding: 2px 1em;
    background-color: white;
    color: black;
    border-left: 2px dotted lightgray;
}

